<html>
    <head>
        <title><%= title %></title>
        <link rel="stylesheet" href="style.css">
    </head>
    <body>
        <form action="/<%= message.id %>/update" method="post" style="display: flex; flex-direction: column; justify-content: center; align-items: center;">
            <label for="title">Title</label>
            <input type="text" name="title" id="title" style="text-align: center;" value="<%= message.title %>">

            <label for="description">Description</label>
            <textarea name="description" id="description" cols="40" rows="10" style="resize: none;">
                <%= message.description %>
            </textarea>

            <button type="submit" style="margin-top: 1rem; padding: 0.5rem 1rem 0.5rem 1rem; font-size: 1rem;">Edit</button>
        </form>
    </body>
</html>